{
  "name": "treemovclient",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"router,vite\" --prefix \"[{name}]\" --kill-others --kill-others-on-fail \"node --no-warnings --experimental-strip-types ./generator/router/generate-router-contract.ts --watch\" \"vite\"",
    "build": "npm run generate:router-contract && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prettier": "node ./scripts/run-prettier.mjs",
    "lint:fix": "node ./scripts/run-eslint-fix.mjs",
    "generate:auth": "kubb generate --config ./generator/api/configs/auth.config.ts",
    "generate:crm-core": "kubb generate --config ./generator/api/configs/crm-core.config.ts",
    "generate:email": "kubb generate --config ./generator/api/configs/email.config.ts",
    "generate:api": "npm run generate:auth && npm run generate:crm-core && npm run generate:email",
    "generate:router-contract": "node --no-warnings --experimental-strip-types ./generator/router/generate-router-contract.ts",
    "watch:router-contract": "node --no-warnings --experimental-strip-types ./generator/router/generate-router-contract.ts --watch",
    "circular-imports-checker": "npx madge --circular --extensions ts,tsx --ts-config tsconfig.app.json src",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@dnd-kit/react": "^0.3.2",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@uidotdev/usehooks": "^2.4.1",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "color": "^5.0.3",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lodash-es": "^4.17.23",
    "lucide-react": "^0.577.0",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "mobx-react-observer": "^1.1.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "qs": "^6.15.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-intersection-observer": "^10.0.3",
    "react-resizable-panels": "^4.7.1",
    "react-router": "^7.13.1",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "universal-cookie": "^8.0.1",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@kubb/cli": "^4.31.6",
    "@kubb/core": "^4.31.6",
    "@kubb/plugin-client": "^4.31.6",
    "@kubb/plugin-oas": "^4.31.6",
    "@kubb/plugin-react-query": "^4.31.6",
    "@kubb/plugin-ts": "^4.31.6",
    "@neodx/svg": "^0.8.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.0",
    "@types/qs": "^6.15.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": "^22.16.x"
  }
}
